HTTP_PORT=8001
HTTPS_PORT=8081
DB_LINK=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
CLIENT_HOST=http://localhost:5173,http://localhost:8080

# Optional runtime tuning
PYTHON_BIN=python
PIPELINE_TIMEOUT_MS=300000
RECOMMEND_TIMEOUT_MS=900000
MAX_UPLOAD_MB=10
OLLAMA_HOST=http://127.0.0.1:11434
